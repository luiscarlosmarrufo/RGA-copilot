# =====================================================================
# RGA Financial Copilot / PHI OMEGA — environment variables
# Copy to `.env` and fill in. NEVER commit `.env`.
# =====================================================================

# ---- App -----------------------------------------------------------
APP_ENV=development                 # development | staging | production
APP_PORT=8000
APP_LOG_LEVEL=info
APP_TIMEZONE=America/Mexico_City
APP_LANGUAGE=es-MX                  # user-facing language; do not change

# ---- Frontend ------------------------------------------------------
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ---- Supabase / Postgres ------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-only, never expose to browser
SUPABASE_DB_URL=                    # postgres://… for migrations/admin
SUPABASE_JWT_SECRET=

# ---- Anthropic / Claude -------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_PRIMARY_MODEL=claude-opus-4-7
ANTHROPIC_COMPRESSION_MODEL=claude-haiku-4-5-20251001
LLM_MEMORY_TOKEN_BUDGET=6000        # compress if memory exceeds this

# ---- Google Maps Places -------------------------------------------
GOOGLE_MAPS_API_KEY=
PLACES_DEFAULT_RADIUS_METERS=1500   # 1–3 km; per-call override allowed
PLACES_CACHE_TTL_HOURS=24
PLACES_LANGUAGE=es

# ---- Pytrends (async only) ----------------------------------------
PYTRENDS_ENABLED=true
PYTRENDS_CRON=0 */6 * * *           # never synchronous; only via scheduler
PYTRENDS_GEO=MX
PYTRENDS_HL=es-MX

# ---- Queue / background jobs --------------------------------------
REDIS_URL=redis://redis:6379/0
QUEUE_NAME=rga-jobs

# ---- Storage -------------------------------------------------------
UPLOAD_MAX_MB=50
UPLOAD_TMP_DIR=/tmp/rga-uploads     # ephemeral; never persistent client data here

# ---- Security ------------------------------------------------------
SESSION_SECRET=
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ---- Observability -------------------------------------------------
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# ---- Feature flags -------------------------------------------------
FEATURE_PLACES_ENABLED=true
FEATURE_PYTRENDS_ENABLED=true
FEATURE_REPORTS_ENABLED=false       # Phase 7
